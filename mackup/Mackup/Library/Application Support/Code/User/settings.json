{
  // Themes 👇
  // "workbench.colorTheme": "GitHub Dark Default",
  // "workbench.colorTheme": "One Dark Pro Darker",
  "workbench.colorTheme": "Dark 2026",
  // Typography 👇
  // "editor.fontFamily": "Hack Nerd Font",
  "editor.fontFamily": "JetBrainsMono Nerd Font",
  // "editor.fontFamily": "'FiraCode-Retina', monospace",
  // "editor.fontFamily": "'Monaspace Neon', monospace",
  "editor.fontFamily": "'SF Mono', monospace",
  "editor.fontSize": 15.5,
  "editor.lineHeight": 1.6,
  "terminal.integrated.fontSize": 13,
  // "editor.inlineSuggest.fontFamily": "'Monaspace Krypton', monospace",
  // "editor.fontWeight": "450", // Retina !! Only works with FiraCode-VF.ttf installed, see below when using separated font files (the normal case).
  // "editor.fontLigatures": true,
  // "editor.fontLigatures": "'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08'",
  "editor.fontLigatures": "'ss01','ss05','dlig'",
  // fontLigatures for Monaspace Neon 👇
  // "editor.fontLigatures": "'calt', 'ss01', 'ss02', 'ss03', 'ss07', 'ss08', 'ss09', 'liga'",
  "editor.renderWhitespace": "trailing",
  "editor.glyphMargin": false,
  "editor.copyWithSyntaxHighlighting": false,
  "editor.minimap.enabled": false,
  "editor.inlineSuggest.enabled": true,
  "editor.linkedEditing": true,
  "editor.wordWrap": "wordWrapColumn",
  "editor.cursorBlinking": "expand",
  "editor.smoothScrolling": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.minimap.showSlider": "always",
  "editor.snippetSuggestions": "top",
  "editor.mouseWheelZoom": true,
  "editor.stickyScroll.enabled": true,
  "editor.detectIndentation": false,
  "editor.tabSize": 2,
  "editor.accessibilitySupport": "off",
  "editor.padding.top": 12,
  // Git settings
  "git.enabled": true,
  "git.path": "/usr/bin/git",
  "git.confirmSync": false,
  // TypeScript settings
  "totalTypeScript.hideAllTips": false,
  "totalTypeScript.hideBasicTips": false,
  "totalTypeScript.hiddenTips": [
    "basic-types",
    "any-type",
    "typing-function-parameters",
    "non-null-expression",
    "variable-type-annotation",
    "ts-object-type",
    "union-type",
    "null-keyword",
    "optional-object-property",
    "as-assertion",
    "array-type",
    "function-return-type",
    "passing-generics-to-types",
    "type-alias-declaration",
    "pick-utility-type",
    "literal-type",
    "interface-declaration"
  ],
  "typescript.updateImportsOnFileMove.enabled": "never",
  // Default formatter settings
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "explorer.sortOrder": "type",
  "workbench.tree.indent": 15,
  "workbench.sideBar.location": "right",
  // GitHub Copilot settings
  "github.copilot.enable": {
    "*": true,
  },
  "github.copilot.advanced": {
    "slashCommands": {
      "createWorkspace": true,
      "search": true,
    },
  },
  // Error Lens settings
  "errorLens.fontSize": "10px",
  "errorLens.fontStyleItalic": true,
  // Spell check settings
  "cSpell.userWords": [
    "autopause",
    "BEONIC",
    "catppuccin",
    "Catppuccin",
    "classname",
    "clsx",
    "datetime",
    "embla",
    "Fira",
    "fullwidth",
    "gatsby",
    "groq",
    "hotspot",
    "jetbrains",
    "klaviyo",
    "lucide",
    "opengraph",
    "pkgs",
    "poimandres",
    "simpli",
    "Simplisafe",
    "Swiper",
    "tailwindcss",
    "testid",
    "textbox",
    "Thresolds",
    "Topbar",
    "Treshold",
    "webp",
    "worldsprings",
  ],
  "cSpell.language": "es,en",
  // ESLint settings
  // "eslint.codeActionsOnSave.rules": null,
  // "eslint.codeActionsOnSave.rules": ["unused-imports/no-unused-imports"],
  "eslint.format.enable": false,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
  },
  // Diff editor settings
  "diffEditor.renderSideBySide": false,
  "diffEditor.wordWrap": "on",
  // Miscellaneous settings
  "editor.formatOnSave": true,
  "editor.quickSuggestions": {
    "strings": "on",
  },
  "editor.hover.delay": 700,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "chat.editor.wordWrap": "on",
  // Search exclude settings
  "search.exclude": {
    "**/vendor/{[^l],?[^ai]}*": true,
    "**/public/{[^i],?[^n]}*": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/_ide_helper.php": true,
    "**/composer.lock": true,
    "**/package-lock.json": true,
    "storage": true,
    ".phpunit.result.cache": true,
  },
  // "explorer.fileNesting.expand": false,
  // "explorer.fileNesting.enabled": true,
  // "explorer.fileNesting.patterns": {
  //   "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, *.config.ts, *.config.mjs, *.json, next-env.d.ts"
  // },
  "window.commandCenter": false,
  "workbench.editor.tabSizing": "shrink",
  "workbench.iconTheme": "material-icon-theme",
  "claudeCode.preferredLocation": "sidebar",
  "claudeCode.selectedModel": "default",
  "editor.quickSuggestionsDelay": 100,
  "editor.suggest.maxVisibleSuggestions": 8,
  // Limita el número de líneas para mejorar scroll
  "editor.maxTokenizationLineLength": 20000,
  // Desactiva moverse automaticamente en explorer para repos grandes
  // "explorer.autoReveal": false,
  // ========== FILES & WATCHER ==========
  // Excluye archivos del file watcher (crítico para monorepos)
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/.hg/store/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.next/**": true,
    "**/coverage/**": true,
    "**/storybook-static/**": true,
  },
  // Oculta archivos del explorer
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/.next": true,
    "**/coverage": true,
    "**/*.map": true,
  },
  // ========== TYPESCRIPT PERFORMANCE ==========
  // Aumenta memoria para el servidor de TypeScript
  "typescript.tsserver.maxTsServerMemory": 4096,
  // Desactiva auto-import en sugerencias (usa el command palette en su lugar)
  "typescript.suggest.autoImports": false,
  // Limita búsqueda de símbolos
  "typescript.workspaceSymbols.scope": "currentProject",
  // ========== SEARCH PERFORMANCE ==========
  "search.maxResults": 1000,
  "search.collapseResults": "auto",
  "search.searchOnType": false,
  // ========== GIT PERFORMANCE ==========
  // Desactiva decoraciones en el gutter para mejorar performance
  "git.decorations.enabled": false,
  // Desactiva blame annotations (consume recursos)
  "git.blame.editorDecoration.enabled": false,
  // Autofetch solo manual en repos grandes
  "git.autofetch": false,
  "workbench.editor.highlightModifiedTabs": true,
  "editor.colorDecorators": false,
  // Specific rules for TaskRabbit
  "eslint.options": {
    "overrideConfig": {
      "rules": {
        "@typescript-eslint/no-unused-vars": "error",
        "import/no-duplicates": "error",
      },
    },
  },
  "markdown.preview.fontSize": 16,
  "chat.editor.fontSize": 14,
  "chat.fontSize": 14,
}