{
    // Window settings
    "window.zoomLevel": 0.2,
    // "window.titleBarStyle": "native",
    // "workbench.productIconTheme": "icons-carbon",
    // Terminal settings
    "terminal.integrated.fontSize": 14,
    // "terminal.integrated.lineHeight": 1.1,
    // "terminal.integrated.letterSpacing": 1,
    // Editor appearance settings
    // "editor.fontFamily": "Hack Nerd Font Mono",
    "editor.fontFamily": "GeistMono Nerd Font Mono",
    // "editor.fontFamily": "SF Mono",
    "editor.fontSize": 18,
    // "editor.lineHeight": 2,
    // "editor.fontLigatures": "'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08'",
    // "editor.fontLigatures": true,
    "editor.renderWhitespace": "trailing",
    "editor.glyphMargin": false,
    "editor.copyWithSyntaxHighlighting": false,
    "editor.minimap.enabled": false,
    "editor.inlineSuggest.enabled": true,
    "editor.linkedEditing": true,
    "editor.wordWrap": "wordWrapColumn",
    "editor.cursorBlinking": "expand",
    "editor.smoothScrolling": true,
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
    "editor.minimap.showSlider": "always",
    "editor.snippetSuggestions": "top",
    "editor.stickyScroll.enabled": true,
    "editor.accessibilitySupport": "off",
    "editor.detectIndentation": false,
    "editor.formatOnSave": true,
    // Git settings
    "git.enabled": true,
    "git.path": "/usr/bin/git",
    "git.confirmSync": false,
    // totalTypeScript settings
    "totalTypeScript.hideAllTips": false,
    "totalTypeScript.hideBasicTips": false,
    "totalTypeScript.hiddenTips": [
        "basic-types",
        "any-type",
        "typing-function-parameters",
        "non-null-expression",
        "variable-type-annotation",
        "ts-object-type",
        "union-type",
        "null-keyword",
        "optional-object-property",
        "as-assertion",
        "array-type",
        "function-return-type",
        "passing-generics-to-types",
        "type-alias-declaration",
        "pick-utility-type",
        "literal-type",
        "generic-slots-in-functions",
        "interface-declaration",
        "typeof",
        "readonly-utility-type",
        "readonly-object-property",
        "partial-utility-type"
    ],
    "typescript.updateImportsOnFileMove.enabled": "never",
    // Default formatter settings
    // "editor.defaultFormatter": "esbenp.prettier-vscode",
    "explorer.sortOrder": "type",
    "workbench.sideBar.location": "right",
    // Error Lens settings
    "errorLens.fontSize": "10px",
    "errorLens.fontStyleItalic": true,
    // Spell check settings
    "cSpell.userWords": [
        "AFTERHOURS",
        "autopause",
        "BEONIC",
        "buzzy",
        "camelcase",
        "catppuccin",
        "Catppuccin",
        "classname",
        "clsx",
        "coloquial",
        "commercetools",
        "Commercetools",
        "Contentful",
        "ctas",
        "CTFL",
        "datetime",
        "ecomm",
        "embla",
        "esbenp",
        "faqs",
        "fieldsets",
        "Fira",
        "fullwidth",
        "geist",
        "glowy",
        "groq",
        "grotesk",
        "heartoftheland",
        "hotspot",
        "jetbrains",
        "klaviyo",
        "lucide",
        "morpher",
        "nids",
        "Ninetailed",
        "nums",
        "Nuqs",
        "odmon",
        "ogimage",
        "OPENAI",
        "opengraph",
        "Optimizely",
        "Parens",
        "pkgs",
        "poimandres",
        "portabletext",
        "pretitle",
        "rbga",
        "rgba",
        "saas",
        "skus",
        "strikethrough",
        "Swiper",
        "tailwindcss",
        "testid",
        "textbox",
        "Thresolds",
        "topbar",
        "Topbar",
        "Treshold",
        "trpc",
        "truz",
        "turbopack",
        "unpublishing",
        "webp",
        "worldsprings",
        "zion"
    ],
    "cSpell.language": "es,en",
    // Diff editor settings
    "diffEditor.renderSideBySide": false,
    "diffEditor.wordWrap": "on",
    // Miscellaneous settings
    // "editor.quickSuggestions": {
    //   "strings": "on"
    // },
    // "editor.hover.delay": 700,
    // "workbench.editor.enablePreviewFromQuickOpen": false,
    // "chat.editor.wordWrap": "on",
    // Search exclude settings
    "search.exclude": {
        "**/vendor/{[^l],?[^ai]}*": true,
        "**/public/{[^i],?[^n]}*": true,
        "**/node_modules": true,
        "**/dist": true,
        "**/_ide_helper.php": true,
        "**/composer.lock": true,
        "**/package-lock.json": true,
        "storage": true,
        ".phpunit.result.cache": true
    },
    "symbols.hidesExplorerArrows": false,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.enabled": true,
    // "explorer.fileNesting.patterns": {
    //   "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, *.config.ts, *.config.mjs, *.json, next-env.d.ts, .gitignore, *.md, .cursorrules, .env*, .eslint*, .prettier*, .stylelint*, sanity.*, .lintstaged*, *.config.js, *.editorconfig"
    // },
    "update.mode": "default",
    "window.commandCenter": false,
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.editor.tabSizing": "shrink",
    "editor.colorDecorators": false,
    "workbench.iconTheme": "symbols",
    "svgPreview.style": {
        "html": {
            "background": "white"
        }
    },
    "workbench.colorTheme": "GitHub Dark Default",
    "window.newWindowProfile": "Mayco",
}